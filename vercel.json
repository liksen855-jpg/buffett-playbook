
{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/pchem", "dest": "/pchem.html" },
    { "src": "/mecon", "dest": "/mecon.html" },
    { "src": "/macro-intelligence", "dest": "/macro_intelligence/index.html" },
    { "src": "/data/(.*)", "dest": "/macro_intelligence/data/$1" },
    { "src": "/siv/(.*)", "dest": "/siv/$1" },
    { "src": "/screener", "dest": "/siv/Screener.html" },
    { "src": "/terminal", "dest": "/siv/Members.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1.html" }
  ]
}
